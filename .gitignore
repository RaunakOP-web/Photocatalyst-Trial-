# ── Raw data (may contain unpublished research) ──
data/raw/*.csv
data/raw/*.json
data/raw/*.xlsx
data/raw/*.xlsm

# ── Processed data (regenerated by pipeline) ──
data/processed/

# ── Saved models ──
models/*.joblib
models/*.pkl

# ── Python caches ──
__pycache__/
*.egg-info/
dist/
build/

# ── Jupyter checkpoints ──
.ipynb_checkpoints/

# ── OS junk ──
.DS_Store
Thumbs.db

# ── Environment ──
.env
venv/
env/
.venv/

# ── Logs ──
*.log
